# Copy this file to .env and fill in real values. Never commit .env.

ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/data_refinery
DATABASE_POOL_SIZE=20

# --- Redis (Celery broker + rate-limit state) ---
REDIS_URL=redis://localhost:6379/0

# --- GitHub official API ---
# Personal access token with public read scope (or a GitHub App token).
GITHUB_TOKEN=
GITHUB_APP_IDENTIFIER=b2b-saas-data-refinery (contact: data-team@example.com)

# --- Reddit official API (PRAW) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=b2b-saas-data-refinery/0.1 (by /u/your-reddit-username)

# --- Product Hunt official API ---
PRODUCTHUNT_API_TOKEN=

# --- API ---
API_SECRET_KEY=
MAX_RETRIES_DEFAULT=3
